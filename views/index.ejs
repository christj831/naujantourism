<%- include('partials/header') %>

<script>(function(){ try { localStorage.removeItem('role'); } catch (e) {} })();</script>

<header class="hero-section position-relative overflow-hidden">
    
    <div id="heroCarousel" class="carousel slide carousel-fade position-absolute top-0 start-0 w-100 h-100" data-bs-ride="carousel">
        <div class="carousel-inner w-100 h-100">
            <div class="carousel-item active h-100">
                <div class="hero-bg-img" style="background-image: url('/images/lake.jpg');"></div>
            </div>
            <div class="carousel-item h-100">
                <div class="hero-bg-img" style="background-image: url('/images/simbahan/main.jpg');"></div>
            </div>
            <div class="carousel-item h-100">
                <div class="hero-bg-img" style="background-image: url('/images/liwasang.jpg');"></div>
            </div>
            <div class="carousel-item h-100">
                <div class="hero-bg-img" style="background-image: url('/images/333-steps.jpg');"></div>
            </div>
        </div>
    </div>

    <div class="hero-overlay position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center text-center">
        <div class="container text-white z-2"> <h5 class="text-uppercase letter-spacing-2 mb-3">Welcome to Oriental Mindoro</h5>
            <h1 class="hero-title">Discover Naujan</h1>
            <p class="lead mb-4 fs-4">“Naujan: Experience Nature, Culture, and Adventure.”</p>
            <a href="/explore" class="btn btn-explore">Explore Now</a>
        </div>
    </div>

    <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark opacity-50 z-1"></div>

</header>

<section class="py-5 text-center container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="section-title text-primary">Love Naujan</h2>
            <p class="lead text-muted mt-3">
                Experience the serene beauty of Naujan Lake, walk through the historic ruins of Bancuro, 
                and taste the local flavors of Mindoro. Naujan is your gateway to nature and history.
            </p>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <h3 class="mb-5 text-center fw-bold">Top Attractions</h3>
        <p class="text-center text-muted small mb-4">Most visited places — based on recent page views</p>
        <div class="row g-4">
            <% featured.forEach(function(spot, index) { %>
                <div class="col-md-4 d-flex align-items-stretch">
                    <div class="card h-100 border-0 shadow-sm hover-card w-100">
                        <div class="position-relative">
                            <img src="<%= spot.image %>" class="card-img-top" alt="<%= spot.name %>" style="height: 250px; object-fit: cover;">
                            <% if (spot.visits !== undefined && spot.visits > 0 && index === 0) { %>
                                <span class="position-absolute top-0 start-0 m-2 badge bg-warning text-dark">Most visited</span>
                            <% } %>
                            <% if (spot.visits !== undefined && spot.visits > 0) { %>
                                <span class="position-absolute top-0 end-0 m-2 badge bg-dark"><%= spot.visits %> views</span>
                            <% } %>
                        </div>
                        
                        <div class="card-body text-center p-4 d-flex flex-column">
                            
                            <div class="mb-2 d-flex flex-column justify-content-center" style="height: 80px;">
                                <div>
                                    <span class="badge bg-primary mb-2"><%= spot.category %></span>
                                    <h4 class="card-title fw-bold m-0"><%= spot.name %></h4>
                                </div>
                            </div>
        
                            <p class="card-text text-muted small mb-4" 
                               style="height: 60px; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                               <%= spot.desc %>
                            </p>
                            
                            <div class="mt-auto">
                                <a href="/attraction/<%= spot.id %>" class="btn btn-primary rounded-pill px-4">View Map & Details</a>
                            </div>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</section>

<section class="py-5 text-center container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h2 class="section-title text-primary">About Naujan</h2>
            <p class="lead text-muted mt-3">
                Naujan is a first-class municipality in Oriental Mindoro, rich in culture, history, and natural wonders. 
                Whether you are looking for a peaceful retreat by the lake or a journey through historic ruins, 
                Naujan offers an unforgettable experience.
            </p>
            
            <h5 class="mt-4 fw-bold">Connect With Us</h5>
            <div class="mt-3">
                <a href="https://web.facebook.com/NaujanTourism" target="_blank" class="btn btn-primary rounded-pill px-4 py-2 me-2 shadow-sm">
                    <i class="fab fa-facebook-f me-2"></i> Facebook
                </a>
                
                <a href="https://instagram.com" target="_blank" class="btn btn-danger rounded-pill px-4 py-2 shadow-sm" style="background: #E1306C; border-color: #E1306C;">
                    <i class="fab fa-instagram me-2"></i> Instagram
                </a>
            </div>
        </div>
    </div>
</section>

<%- include('partials/footer') %>